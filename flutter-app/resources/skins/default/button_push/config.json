{
  "animations": {
    "press": {
      "duration_ms": 100,
      "curve": "easeOutCubic",
      "scale": 0.95,
      "opacity": 1.0
    },
    "release": {
      "duration_ms": 400,
      "curve": "elasticOut",
      "scale": 1.0
    },
    "hover": {
      "duration_ms": 200,
      "curve": "linear",
      "glow_boost": 0.1
    }
  },
  "haptics": {
    "on_press": "medium",
    "on_release": "light"
  },
  "audio": {
    "press_sample": "click.mp3",
    "release_sample": "clack.mp3",
    "volume": 0.5
  }
}
