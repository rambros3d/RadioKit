{
  "renderingLayers": [
    {
      "type": "box",
      "props": {
        "width": 12.4,
        "height": 12.4,
        "borderRadius": 3.6,
        "color": "#111111",
        "margin": 1.2,
        "boxShadow": [
          { "color": "#88a5bf", "opacity": 0.3, "offsetX": 0.8, "offsetY": 0.4, "blur": 2.4 },
          { "color": "#000000", "opacity": 0.5, "offsetX": -0.8, "offsetY": -0.4, "blur": 2.4 }
        ]
      },
      "visibility": { "on": false }
    },
    {
      "type": "box",
      "props": {
        "width": 12.4,
        "height": 12.4,
        "borderRadius": 3.6,
        "color": "#111111",
        "margin": 1.2,
        "boxShadow": [
          { "inset": true, "color": "#000000", "opacity": 0.6, "offsetX": 0.6, "offsetY": 0.6, "blur": 1.4 },
          { "inset": true, "color": "#ffffff", "opacity": 0.1, "offsetX": -0.6, "offsetY": -0.6, "blur": 1.4 }
        ]
      },
      "visibility": { "on": true }
    },
    {
      "type": "alignment",
      "props": {
        "align": "center",
        "child": {
          "type": "column",
          "props": {
            "mainAxisAlignment": "center",
            "children": [
              {
                "type": "icon",
                "props": {
                  "size": 4.8,
                  "color": "$state.isOn ? #primary : $state.isPressed ? #primary : #onSurface",
                  "shadows": [
                    { "color": "#000000", "opacity": 0.4, "offsetX": 0.2, "offsetY": 0.2, "blur": 0.4 }
                  ]
                }
              },
              {
                "type": "text",
                "props": {
                  "text": "$state.label",
                  "size": 2.0,
                  "color": "$state.isOn ? #primary : #onSurface",
                  "margin": 0.8
                }
              }
            ]
          }
        }
      }
    }
  ]
}
