{
  "renderingLayers": [
    {
      "type": "neumorphic",
      "props": {
        "depth": "@neumorphicDepth",
        "intensity": "@neumorphicIntensity",
        "borderRadius": 2.4,
        "color": "#surface",
        "margin": 0.4
      }
    },
    {
      "type": "icon",
      "props": {
        "icon": "$state.icon",
        "color": "#primary",
        "size": 4.8
      }
    }
  ],
  "physics": {
    "damping": 1.0,
    "stiffness": 150.0
  }
}
