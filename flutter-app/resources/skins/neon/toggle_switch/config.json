{
  "renderingLayers": [
    {
      "type": "switch",
      "props": {
        "animation": "squishy"
      },
      "children": [
        {
          "type": "box",
          "props": {
            "role": "track",
            "width": 12.8,
            "height": 6.8,
            "borderRadius": 20.0,
            "color": "$state.isOn ? #toggleActive : #toggleTrack",
            "boxShadow": [
              { "inset": true, "color": "#000000", "opacity": 0.15, "offsetX": 0.2, "offsetY": 0.4, "blur": 0.8 },
              { "inset": true, "color": "#ffffff", "opacity": 0.25, "offsetX": -0.2, "offsetY": -0.4, "blur": 0.8 }
            ]
          }
        },
        {
          "type": "box",
          "props": {
            "role": "thumb",
            "width": 5.6,
            "height": 5.6,
            "borderRadius": 20.0,
            "gradient": {
              "type": "linear",
              "colors": ["#ffffff", "#dfe6ec"],
              "begin": "$state.isPressed ? bottomLeft : topRight",
              "end": "$state.isPressed ? topRight : bottomLeft"
            },
            "boxShadow": [
              { "color": "#000000", "opacity": 0.2, "offsetX": 0.4, "offsetY": 0.4, "blur": 0.8 },
              { "inset": true, "color": "#ffffff", "opacity": 0.5, "offsetX": 0.2, "offsetY": 0.2, "blur": 0.4 }
            ]
          }
        }
      ]
    }
  ]
}
