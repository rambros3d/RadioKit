{
  "renderingLayers": [
    {
      "type": "joystick",
      "props": {
        "size": 150,
          "travel": 0.5,
        "base": {
          "type": "box",
          "props": {
            "width": 18,
            "height": 18,
            "borderRadius": 50,
            "color": "#surface",
            "gradient": {
              "type": "radial",
              "colors": ["#444444", "#111111"],
              "center": "bottomRight",
              "radius": 1.5
            },
            "boxShadow": [
              { "color": "#000000", "opacity": 0.5, "offsetX": 2, "offsetY": 2, "blur": 4 },
              { "color": "#ffffff", "opacity": 0.05, "offsetX": -1, "offsetY": -1, "blur": 2 }
            ]
          }
        },
        "stick": {
          "type": "box",
          "props": {
            "width": 8,
            "height": 8,
            "borderRadius": 50,
            "color": "#primary",
            "gradient": {
              "type": "radial",
              "colors": ["#39FF14", "#20880a"],
              "center": "topLeft",
              "radius": 1.2
            },
            "boxShadow": [
              { "color": "#39FF14", "opacity": 0.4, "offsetX": 0, "offsetY": 0, "blur": 15 },
              { "color": "#000000", "opacity": 0.6, "offsetX": 2, "offsetY": 2, "blur": 6 }
            ]
          }
        }
      }
    }
  ]
}
