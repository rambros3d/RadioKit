{
  "name": "RadioKit",
  "version": "0.1.0",
  "description": "Control Arduino with a smartphone over BLE or USB Serial. Define widgets in code; they appear automatically in the RadioKit app.",
  "keywords": ["ble", "bluetooth", "remote control", "gui", "esp32"],
  "authors": [
    {
      "name": "RadioKit Contributors",
      "url": "https://github.com/rambros3d/RadioKit"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/rambros3d/RadioKit"
  },
  "license": "MIT",
  "homepage": "https://github.com/rambros3d/RadioKit",
  "frameworks": "arduino",
  "platforms": "espressif32",
  "dependencies": [
    {
      "name": "NimBLE-Arduino",
      "version": "^1.4.1"
    }
  ],
  "build": {
    "srcDir": "src",
    "includeDir": "src",
    "extraScript": ""
  }
